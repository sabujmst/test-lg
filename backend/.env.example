# Server Configuration
PORT=5000

# Execution Source: 'local' to run diagnostics on the backend server, 'router' to run on the Arista EOS router
EXECUTION_SOURCE=local

# Arista EOS Router SSH Credentials (only used if EXECUTION_SOURCE=router)
ROUTER_HOST=192.168.1.1
ROUTER_PORT=22
ROUTER_USER=admin
ROUTER_PASSWORD=admin
# If your Arista router uses ssh key instead of password, uncomment and configure:
# ROUTER_KEY_PATH=/path/to/private/key
